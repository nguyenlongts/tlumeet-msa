{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "authservice",
          "Port": 8080
        }
      ]
    },
    {
      "UpstreamPathTemplate": "/hubs/notification",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/hubs/notification",
      "DownstreamScheme": "ws",
      "DownstreamHostAndPorts": [
        {
          "Host": "notiservice",
          "Port": 8080
        }
      ]
    },
    {
      "UpstreamPathTemplate": "/api/meeting/check/{roomCode}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/meeting/check/{roomCode}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "meetingservice",
          "Port": 8080
        }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/meeting/{roomCode}/status",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/meeting/{roomCode}/status",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "meetingservice",
          "Port": 8080
        }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/meeting/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/meeting/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "meetingservice",
          "Port": 8080
        }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/jaas/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/jaas/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "meetingservice",
          "Port": 8080
        }
      ]
    },

    {
      "UpstreamPathTemplate": "/api/notification/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ],
      "DownstreamPathTemplate": "/api/notification/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "notiservice",
          "Port": 8080
        }
      ]
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5555"
  }
}